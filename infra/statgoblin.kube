# Quadlet unit: runs pod.yaml under systemd so the pod survives reboot.
# Install (rootless):
#   cp statgoblin.kube ~/.config/containers/systemd/
#   systemctl --user daemon-reload && systemctl --user start statgoblin
[Unit]
Description=StatGoblin pod
After=network-online.target
Wants=network-online.target

[Kube]
Yaml=/opt/statgoblin/infra/pod.yaml

[Install]
WantedBy=default.target
