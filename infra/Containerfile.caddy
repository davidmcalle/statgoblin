# Caddy with the DuckDNS DNS-01 module — certs without opening port 80.
# Build once on the VM: podman build -t localhost/rollwatch-caddy -f Containerfile.caddy .
FROM docker.io/library/caddy:2-builder AS builder
RUN xcaddy build --with github.com/caddy-dns/duckdns

FROM docker.io/library/caddy:2
COPY --from=builder /usr/bin/caddy /usr/bin/caddy
