# Terminates TLS for statgoblin.com and proxies to the app in the same pod.
# Stock Caddy: cert via the HTTP-01 challenge — ports 80 AND 443 must reach
# this container (80 also serves the ACME validation + https redirect).
{$SITE_ADDRESS} {
	encode gzip
	reverse_proxy localhost:3000
}

www.{$SITE_ADDRESS} {
	redir https://{$SITE_ADDRESS}{uri} permanent
}
