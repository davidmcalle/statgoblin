// Rollwatch schema. Conventions: tables snake_case plural, columns snake_case,
// UUID PKs generated by Postgres, timestamptz UTC. Connection URL lives in
// prisma.config.ts (Prisma 7), not here. Users live in Clerk — member rows
// reference Clerk user ids, no local users table.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name  String
  image String @default("")
  // Clerk user id of the creator — the only user who may edit the campaign,
  // see the ingest credentials, or regenerate the key.
  creatorId String @map("creator_id")
  // Shareable code embedded in invite links; joining adds a member row.
  inviteCode String @unique @map("invite_code")
  // sha256 hex of the admin API key the GM pastes into Foundry. The plaintext
  // key is shown once at creation/regeneration and never stored. The campaign
  // UUID alone (visible to all members) cannot authorize ingest.
  ingestKeyHash String   @map("ingest_key_hash")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  members CampaignMember[]
  events  RawEvent[]

  @@map("campaigns")
}

model CampaignMember {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  // Clerk user id.
  userId   String   @map("user_id")
  role     String   @default("player") // 'gm' (creator) | 'player'
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("campaign_members")
}

// ——— Derived layer ————————————————————————————————————————————————————————
// Everything below `raw_events` is disposable: the parser (lib/derive)
// rebuilds it from raw payloads. Never write these tables from anywhere else.

// One row per individual roll inside a message (a midi-qol attack message
// carries attack + damage rolls → two rows). Denormalized on purpose —
// dashboard queries hit this table alone.
model Roll {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String @map("campaign_id") @db.Uuid
  rawEventId String @map("raw_event_id") @db.Uuid
  messageId  String @map("message_id")
  // Position within the message's rolls array; usage cards get index 0.
  rollIndex Int    @map("roll_index")
  rollType  String @map("roll_type")

  actorFid  String? @map("actor_fid")
  actorName String? @map("actor_name")
  tokenFid  String? @map("token_fid")
  tokenName String? @map("token_name")

  authorName String? @map("author_name")
  authorRole String? @map("author_role")

  itemName     String? @map("item_name")
  itemType     String? @map("item_type")
  activityType String? @map("activity_type")

  formula String?
  total   Float?
  // Raw d20 die result (null for damage/healing/usage).
  d20 Int?
  // -1 disadvantage, 0 normal, 1 advantage.
  advantageState Int?    @map("advantage_state")
  isNat20        Boolean @default(false) @map("is_nat20")
  isNat1         Boolean @default(false) @map("is_nat1")

  // midi-qol combat detail, where present.
  isHit       Boolean? @map("is_hit")
  isCritical  Boolean? @map("is_critical")
  damageTotal Float?   @map("damage_total")
  damageType  String?  @map("damage_type")
  targetCount Int?     @map("target_count")

  // Enricher detail (flags.rollwatch).
  ability        String?
  skill          String?
  profMultiplier Float?  @map("prof_multiplier")

  rolledAt  DateTime  @map("rolled_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  rawEvent RawEvent @relation(fields: [rawEventId], references: [id], onDelete: Cascade)

  @@unique([rawEventId, rollIndex])
  @@index([campaignId, rolledAt])
  @@index([campaignId, actorFid])
  @@index([campaignId, rollType])
  @@map("rolls")
}

// Auto-discovered actors per campaign; assignment links them to Clerk users
// (players claim characters, GM owns the monsters).
model Actor {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId     String   @map("campaign_id") @db.Uuid
  foundryActorId String   @map("foundry_actor_id")
  name           String
  image          String   @default("")
  assignedUserId String?  @map("assigned_user_id")
  rollCount      Int      @default(0) @map("roll_count")
  lastSeenAt     DateTime @map("last_seen_at") @db.Timestamptz(6)

  @@unique([campaignId, foundryActorId])
  @@index([campaignId, assignedUserId])
  @@map("actors")
}

// Parser bookkeeping: bump PARSER_VERSION in lib/derive to mark all previously
// derived rows stale; reprocess rebuilds campaigns whose version lags.
model DeriveState {
  campaignId    String   @id @map("campaign_id") @db.Uuid
  parserVersion Int      @map("parser_version")
  derivedAt     DateTime @updatedAt @map("derived_at") @db.Timestamptz(6)

  @@map("derive_state")
}

// One row per Foundry chat message, upserted on every event. `payload` is the
// latest collectedData mirrored verbatim (JSONB) — the source of truth that
// derived tables are rebuilt from later. Deletes keep the last payload and
// stamp deletedAt so stats can drop the roll without losing history.
model RawEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId    String    @map("campaign_id") @db.Uuid
  messageId     String    @map("message_id")
  lastEventType String    @map("last_event_type")
  payload       Json?
  // How many POSTs touched this message (created + updates + client duplicates).
  receivedCount Int       @default(1) @map("received_count")
  firstSeenAt   DateTime  @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  rolls    Roll[]

  @@unique([campaignId, messageId])
  @@index([campaignId, updatedAt])
  @@map("raw_events")
}
