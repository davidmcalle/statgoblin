// Rollwatch schema. Conventions: tables snake_case plural, columns snake_case,
// UUID PKs generated by Postgres, timestamptz UTC. Connection URL lives in
// prisma.config.ts (Prisma 7), not here. Users live in Clerk — member rows
// reference Clerk user ids, no local users table.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name  String
  image String @default("")
  // Clerk user id of the creator — the only user who may edit the campaign,
  // see the ingest credentials, or regenerate the key.
  creatorId String @map("creator_id")
  // Shareable code embedded in invite links; joining adds a member row.
  inviteCode String   @unique @map("invite_code")
  // GM switch: death saves rolled while enabled stay hidden from players.
  // Disabling reveals them permanently — `since` marks the current hiding
  // window, so reprocessing can never re-hide previously revealed saves.
  hideDeathSaves      Boolean   @default(false) @map("hide_death_saves")
  hideDeathSavesSince DateTime? @map("hide_death_saves_since") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  // Shared-mutation version stamp: bumped by any change other members should
  // see (assignments, kind tags, deletions, settings). The freshness probe
  // folds this in, so every client's poll picks the change up.
  activityAt DateTime @default(now()) @map("activity_at") @db.Timestamptz(6)
  // Discord webhook for "Send summary" — the GM creates a webhook in their own
  // server/channel and pastes the URL here. Empty = feature off.
  discordWebhookUrl String @default("") @map("discord_webhook_url")

  members CampaignMember[]
  events  RawEvent[]
  apiKeys ApiKey[]

  @@map("campaigns")
}

// Admin API keys for ingest, typical key-system shape: several live keys per
// campaign, individually deletable. Plaintext is shown once at creation and
// never stored — only the sha256 lands here. The campaign UUID alone (visible
// to all members) cannot authorize ingest.
model ApiKey {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String @map("campaign_id") @db.Uuid
  name       String
  // First characters of the key ("rw_ab12cd34…") so the GM can tell keys apart.
  keyPrefix  String    @map("key_prefix")
  keyHash    String    @unique @map("key_hash")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("api_keys")
}

model CampaignMember {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  // Clerk user id.
  userId   String   @map("user_id")
  role     String   @default("player") // 'gm' (creator) | 'player'
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("campaign_members")
}

// ——— Derived layer ————————————————————————————————————————————————————————
// Everything below `raw_events` is disposable: the parser (lib/derive)
// rebuilds it from raw payloads. Never write these tables from anywhere else.

// One row per individual roll inside a message (a midi-qol attack message
// carries attack + damage rolls → two rows). Denormalized on purpose —
// dashboard queries hit this table alone.
model Roll {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String @map("campaign_id") @db.Uuid
  rawEventId String @map("raw_event_id") @db.Uuid
  messageId  String @map("message_id")
  // Position within the message's rolls array; usage cards get index 0.
  rollIndex Int    @map("roll_index")
  rollType  String @map("roll_type")

  actorFid  String? @map("actor_fid")
  actorName String? @map("actor_name")
  // "character" | "npc" (heuristic fallback for events predating module 0.2.1).
  actorType String? @map("actor_type")
  tokenFid  String? @map("token_fid")
  tokenName String? @map("token_name")

  authorName String? @map("author_name")
  authorRole String? @map("author_role")

  itemName     String? @map("item_name")
  itemType     String? @map("item_type")
  activityType String? @map("activity_type")

  formula String?
  total   Float?
  // Every kept die in the roll: [{ f: faces, r: result }]. Feeds the log view.
  dice Json?
  // total minus dice sum — the flat bonus shown as "+2" in the log.
  modifier Float?
  // Roll target (save DC / death-save 10) when dnd5e stamped one.
  dc Int?
  // Raw d20 die result (null for damage/healing/usage).
  d20 Int?
  // -1 disadvantage, 0 normal, 1 advantage.
  advantageState Int?    @map("advantage_state")
  isNat20        Boolean @default(false) @map("is_nat20")
  isNat1         Boolean @default(false) @map("is_nat1")

  // midi-qol combat detail, where present.
  isHit       Boolean? @map("is_hit")
  isCritical  Boolean? @map("is_critical")
  damageTotal Float?   @map("damage_total")
  damageType  String?  @map("damage_type")
  targetCount Int?     @map("target_count")

  // Enricher detail (flags.rollwatch).
  ability        String?
  skill          String?
  profMultiplier Float?  @map("prof_multiplier")

  // GM-hidden (death saves rolled during a hiding window). Player-facing
  // queries exclude these until the GM reveals them.
  isHidden Boolean @default(false) @map("is_hidden")

  rolledAt  DateTime  @map("rolled_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  // Row bookkeeping for the read API's incremental loads. Reprocessing
  // recreates rows, so (messageId, rollIndex) — not id — is the stable key.
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  rawEvent RawEvent @relation(fields: [rawEventId], references: [id], onDelete: Cascade)

  @@unique([rawEventId, rollIndex])
  @@index([campaignId, rolledAt])
  @@index([campaignId, actorFid])
  @@index([campaignId, rollType])
  @@index([campaignId, updatedAt])
  @@map("rolls")
}

// Auto-discovered actors per campaign; assignment links them to Clerk users
// (players claim characters, GM owns the monsters).
model Actor {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId     String   @map("campaign_id") @db.Uuid
  foundryActorId String   @map("foundry_actor_id")
  name           String
  image          String   @default("")
  // "character" | "npc"; drives the automatic PC vs monster bucketing.
  actorType      String?  @map("actor_type")
  // Manual GM tag overriding the automatic kind: "pc" | "npc" | "monster".
  // Auto rule: assigned or typed character → pc; everything else → monster.
  // "npc" (friendly) exists only as an override — the payload can't tell
  // friend from foe.
  kindOverride   String?  @map("kind_override")
  // Challenge rating, npc sheets only.
  cr             Float?
  assignedUserId String?  @map("assigned_user_id")
  rollCount      Int      @default(0) @map("roll_count")
  lastSeenAt     DateTime @map("last_seen_at") @db.Timestamptz(6)

  @@unique([campaignId, foundryActorId])
  @@index([campaignId, assignedUserId])
  @@map("actors")
}

// Generated Discord session summaries, cached so a resend never regenerates
// (or re-bills) the narrative. Keyed by the exact set of session dates the
// GM picked; payload holds the narrative, awards and stat packet.
model SessionSummary {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  // Sorted session dates joined with "," — the cache key for a selection.
  datesKey   String   @map("dates_key")
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([campaignId, datesKey])
  @@map("session_summaries")
}

// Parser bookkeeping: bump PARSER_VERSION in lib/derive to mark all previously
// derived rows stale; reprocess rebuilds campaigns whose version lags.
model DeriveState {
  campaignId    String   @id @map("campaign_id") @db.Uuid
  parserVersion Int      @map("parser_version")
  derivedAt     DateTime @updatedAt @map("derived_at") @db.Timestamptz(6)

  @@map("derive_state")
}

// One row per Foundry chat message, upserted on every event. `payload` is the
// latest collectedData mirrored verbatim (JSONB) — the source of truth that
// derived tables are rebuilt from later. Deletes keep the last payload and
// stamp deletedAt so stats can drop the roll without losing history.
model RawEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId    String    @map("campaign_id") @db.Uuid
  messageId     String    @map("message_id")
  lastEventType String    @map("last_event_type")
  payload       Json?
  // How many POSTs touched this message (created + updates + client duplicates).
  receivedCount Int       @default(1) @map("received_count")
  firstSeenAt   DateTime  @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  rolls    Roll[]

  @@unique([campaignId, messageId])
  @@index([campaignId, updatedAt])
  @@map("raw_events")
}
