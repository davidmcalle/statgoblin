// Rollwatch schema. Conventions: tables snake_case plural, columns snake_case,
// UUID PKs generated by Postgres, timestamptz UTC. Connection URL lives in
// prisma.config.ts (Prisma 7), not here. Users live in Clerk — member rows
// reference Clerk user ids, no local users table.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name  String
  image String @default("")
  // Clerk user id of the creator — the only user who may edit the campaign,
  // see the ingest credentials, or regenerate the key.
  creatorId String @map("creator_id")
  // Shareable code embedded in invite links; joining adds a member row.
  inviteCode String @unique @map("invite_code")
  // sha256 hex of the admin API key the GM pastes into Foundry. The plaintext
  // key is shown once at creation/regeneration and never stored. The campaign
  // UUID alone (visible to all members) cannot authorize ingest.
  ingestKeyHash String   @map("ingest_key_hash")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  members CampaignMember[]
  events  RawEvent[]

  @@map("campaigns")
}

model CampaignMember {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  // Clerk user id.
  userId   String   @map("user_id")
  role     String   @default("player") // 'gm' (creator) | 'player'
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("campaign_members")
}

// One row per Foundry chat message, upserted on every event. `payload` is the
// latest collectedData mirrored verbatim (JSONB) — the source of truth that
// derived tables are rebuilt from later. Deletes keep the last payload and
// stamp deletedAt so stats can drop the roll without losing history.
model RawEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId    String    @map("campaign_id") @db.Uuid
  messageId     String    @map("message_id")
  lastEventType String    @map("last_event_type")
  payload       Json?
  // How many POSTs touched this message (created + updates + client duplicates).
  receivedCount Int       @default(1) @map("received_count")
  firstSeenAt   DateTime  @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, messageId])
  @@index([campaignId, updatedAt])
  @@map("raw_events")
}
