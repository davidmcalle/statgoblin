// Rollwatch schema. Conventions follow chp-tracker: tables snake_case plural,
// columns snake_case, UUID PKs generated by Postgres, timestamptz UTC.
// Connection URL lives in prisma.config.ts (Prisma 7), not here.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  // Secret bearer token the Foundry module sends; identifies + authorizes ingest.
  ingestToken String   @unique @map("ingest_token")
  // Shareable code players enter to join the campaign (used once auth exists).
  joinCode    String   @unique @map("join_code")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  events RawEvent[]

  @@map("campaigns")
}

// One row per Foundry chat message, upserted on every event. `payload` is the
// latest collectedData mirrored verbatim (JSONB) — the source of truth that
// derived tables are rebuilt from later. Deletes keep the last payload and
// stamp deletedAt so stats can drop the roll without losing history.
model RawEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId    String    @map("campaign_id") @db.Uuid
  messageId     String    @map("message_id")
  lastEventType String    @map("last_event_type")
  payload       Json?
  // How many POSTs touched this message (created + updates + client duplicates).
  receivedCount Int       @default(1) @map("received_count")
  firstSeenAt   DateTime  @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, messageId])
  @@index([campaignId, updatedAt])
  @@map("raw_events")
}
